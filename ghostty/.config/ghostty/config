# Theme — managed by the `theme` command (source of truth: ~/.config/theme-mode).
#   light -> Electron Highlighter Day        dark -> Electron Highlighter
# Ghostty can't reload from the CLI, so after switching press cmd+shift+, to apply.
theme = Electron Highlighter

font-size = 16
font-feature = "-calt"
font-feature = "-liga"
font-feature = "-dlig"
window-padding-x = 6
mouse-hide-while-typing = true
clipboard-read = "allow"
macos-titlebar-style = "tabs"
shell-integration = fish
shell-integration-features = "title"
keybind = shift+enter=text:\x1b\r
macos-icon = custom-style
macos-icon-ghost-color = #427eff
macos-icon-screen-color = #141820
macos-icon-frame = plastic
